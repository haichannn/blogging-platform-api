{
    "preset": "psr12",
    "rules": {
        "single_import_per_statement": true,
        "ordered_imports": true,
        "no_unused_imports": true,
        "concat_space": {
            "spacing": "one"
        },
        "single_quote": true,
        "array_indentation": true,
        "simplified_null_return": true,
        "php_unit_method_casing": {
            "case": "snake_case"
        },
        "new_with_parentheses": {
            "named_class": true,
            "anonymous_class": true
        }
    }
}
